# ===========================================
# ARMAFIELD Backend Configuration
# ===========================================

# Domain (required)
# Used by Caddy for automatic HTTPS. Set to your actual domain in production.
DOMAIN=localhost

# ----- Database -----
# Two options:
#
# 1) LOCAL DATABASE (easiest for getting started).
#    Leave DATABASE_URL commented out. POSTGRES_PASSWORD below is used.
#    Start with: docker compose --profile local-db up
#    This spins up a PostgreSQL container alongside the app.
#
# 2) EXTERNAL DATABASE (managed Postgres, AWS RDS, Supabase, etc.).
#    Set DATABASE_URL to your connection string and start with:
#    docker compose up   (without --profile local-db)
#
# DATABASE_URL=postgresql://user:pass@your-db-host:5432/armafield

# PostgreSQL password for the local container (ignored if using external DB).
POSTGRES_PASSWORD=armafield

# Steam API Key (required for admin login)
# Get yours at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Auth.js secret (required)
# Used to sign session tokens. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Test Mode (optional)
# Bypasses Bearer token auth and balance checks. For development only.
# ARMAFIELD_TEST_MODE=enabled-i-know-what-i-am-doing

# Log level (optional, default: info)
# Options: debug, info, warn, error
LOG_LEVEL=info
